# Build outputs
/bin/
/validator/c-libbpf/bin/

# Runtime artifacts
/.bpfcompat/
/.bpfcompat-api/
/reports/*
!/reports/.gitkeep

# VM image cache
/vm/cache/*
!/vm/cache/.gitkeep

# Generated eBPF objects
*.bpf.o

# Runtime-selected fetched artifacts
/artifacts/runtime-selected/

# Local-only private notes
/.private-diligence/
/docs/strategy-private/

# Generated evidence (high-churn local outputs)
/evidence/

# Local demo/example working sets
/examples/aegis-live/

# Generated matrix artifacts (local, environment-dependent)
/matrices/expanded-2026-runnable.yaml
/matrices/expanded-2026-runnable-keep-manual.yaml
/matrices/latest-kernel-runnable.yaml
/matrices/upstream-kernel-runnable.yaml
/matrices/firecracker-*.yaml
/matrices/smoke-*.yaml
/vm/profiles/kernelorg-*.yaml
/vm/profiles/firecracker-*.yaml

# Generated static compatibility site
/public/compatibility/

# Credentials & secrets — never commit (deploy / Hetzner / demo)
# Real env files carry BPFCOMPAT_API_WRITE_KEY etc.; only the .example templates
# are tracked. SSH private keys and TLS material must never land in the repo.
*.env
!*.env.example
*.pem
*.key
*.ppk
id_rsa
id_ecdsa
id_ed25519
*_rsa
*_ed25519
known_hosts
# Local deploy scratch (server IPs, installimage configs, notes)
/.hetzner/
/.secrets/

# Common temporary files
*.log
*.tmp
*.swp
.DS_Store
