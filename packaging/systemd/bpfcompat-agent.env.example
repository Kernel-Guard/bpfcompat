# Copy to /etc/bpfcompat/agent.env and make it readable only by root.
#
# Alpha default is fetch-only. It probes the host, asks the control plane for
# the best verified artifact, downloads it, verifies SHA-256, and writes audit
# output. It does not load eBPF unless an operator adds explicit load flags.

BPFCOMPAT_AGENT_API_URL=https://bpfcompat.example.com
BPFCOMPAT_AGENT_TENANT=acme
BPFCOMPAT_AGENT_PROJECT=aegis-bpf
BPFCOMPAT_AGENT_ARTIFACT_NAME=aegis
BPFCOMPAT_AGENT_ID=

# Secrets. Prefer a per-host, read-only registry token scoped to one
# tenant/project/artifact family. Leave identity token empty unless the
# control plane requires JWT identity.
BPFCOMPAT_AGENT_REGISTRY_TOKEN=
BPFCOMPAT_AGENT_IDENTITY_TOKEN=

# Local state.
BPFCOMPAT_AGENT_WORKDIR=/var/lib/bpfcompat-agent
BPFCOMPAT_AGENT_OUT_DIR=/var/lib/bpfcompat-agent/selected
BPFCOMPAT_AGENT_LAST_RESULT_PATH=/var/lib/bpfcompat-agent/last-apply.json

# Optional selector hints.
BPFCOMPAT_AGENT_TARGET_PROFILE=
BPFCOMPAT_AGENT_VERSION=

# Extra flags for controlled private deployments only. Keep empty for public
# demo/pilot fetch-only mode. Do not put --approve-load here; reviewed host
# loading belongs in bpfcompat-agent-load.service and agent-load.env.
BPFCOMPAT_AGENT_EXTRA_ARGS=
