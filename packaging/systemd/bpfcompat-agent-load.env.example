# Copy to /etc/bpfcompat/agent-load.env before starting
# bpfcompat-agent-load.service. This file is intentionally separate from
# agent.env so scheduled fetch-only delivery cannot accidentally load eBPF.

# Required for approved host loading. The example policy is default-deny;
# edit a specific allow rule before starting bpfcompat-agent-load.service.
BPFCOMPAT_AGENT_LOAD_POLICY_PATH=/etc/bpfcompat/agent-load-policy.yaml
BPFCOMPAT_AGENT_REQUIRE_LOAD_POLICY=true

# Optional manifest supplied by the operator when policy rules need program
# type or attach-kind matching.
BPFCOMPAT_AGENT_MANIFEST_PATH=

# Separate result file for approved-load attempts.
BPFCOMPAT_AGENT_LAST_LOAD_RESULT_PATH=/var/lib/bpfcompat-agent/last-load.json

# Extra reviewed load arguments only. Avoid putting fetch/selection args here;
# those belong in /etc/bpfcompat/agent.env.
BPFCOMPAT_AGENT_LOAD_EXTRA_ARGS=
